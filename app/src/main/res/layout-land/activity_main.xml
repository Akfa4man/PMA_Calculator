<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Левая часть: дисплей -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/tvExpr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:gravity="end"
            android:text="" />

        <TextView
            android:id="@+id/tvValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="34sp"
            android:gravity="end"
            android:text="0"
            android:paddingTop="6dp"
            android:paddingBottom="8dp" />

        <!-- Панель инженерных функций -->
        <LinearLayout
            android:id="@+id/panelScientific"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:paddingTop="8dp">

            <Button
                android:id="@+id/btnSin"
                android:backgroundTint="#FF8C00"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="sin" />

            <Button
                android:id="@+id/btnCos"
                android:backgroundTint="#FF8C00"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="cos" />

            <Button
                android:id="@+id/btnPow"
                android:backgroundTint="#FF8C00"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="x^y" />
        </LinearLayout>
    </LinearLayout>

    <!-- Правая часть: кнопки -->
    <GridLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="2"
        android:columnCount="5"
        android:rowCount="4"
        android:useDefaultMargins="true"
        android:alignmentMode="alignMargins">

        <!-- Row 1 -->
        <Button
            android:id="@+id/btnFunc"
            android:text="FUNC"
            android:backgroundTint="#5c6163"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1" />

        <Button
            android:id="@+id/btnClear"
            android:text="C"
            android:backgroundTint="#B22222"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1" />

        <Button
            android:id="@+id/btnBack"
            android:text="⌫"
            android:backgroundTint="#B22222"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1" />

        <Button
            android:id="@+id/btnDiv"
            android:text="÷"
            android:backgroundTint="#FF8C00"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1" />

        <Button
            android:id="@+id/btnMul"
            android:text="×"
            android:backgroundTint="#FF8C00"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1" />

        <!-- Row 2 -->
        <Button
            android:id="@+id/btn7"
            android:text="7"
            android:backgroundTint="#000000"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1" />

        <Button
            android:id="@+id/btn8"
            android:text="8"
            android:backgroundTint="#000000"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1" />

        <Button
            android:id="@+id/btn9"
            android:text="9"
            android:backgroundTint="#000000"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1" />

        <Button
            android:id="@+id/btnSub"
            android:text="−"
            android:backgroundTint="#FF8C00"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1" />

        <Button
            android:id="@+id/btnAdd"
            android:text="+"
            android:backgroundTint="#FF8C00"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1" />

        <!-- Row 3 -->
        <Button
            android:id="@+id/btn4"
            android:text="4"
            android:backgroundTint="#000000"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1" />

        <Button
            android:id="@+id/btn5"
            android:text="5"
            android:backgroundTint="#000000"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1" />

        <Button
            android:id="@+id/btn6"
            android:text="6"
            android:backgroundTint="#000000"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1" />

        <Button
            android:id="@+id/btnComma"
            android:text=","
            android:backgroundTint="#000000"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1" />

        <Button
            android:id="@+id/btnEq"
            android:text="="
            android:backgroundTint="#FF8C00"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1" />

        <!-- Row 4 -->
        <Button
            android:id="@+id/btn1"
            android:text="1"
            android:backgroundTint="#000000"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1" />

        <Button
            android:id="@+id/btn2"
            android:text="2"
            android:backgroundTint="#000000"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1" />

        <Button
            android:id="@+id/btn3"
            android:text="3"
            android:backgroundTint="#000000"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1" />

        <Button
            android:id="@+id/btn0"
            android:text="0"
            android:backgroundTint="#000000"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="2"
            android:layout_rowWeight="1"
            android:layout_columnSpan="2" />

        <Space
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1" />

    </GridLayout>

</LinearLayout>